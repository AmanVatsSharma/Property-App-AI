{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@property-app-ai/shared": ["../../libs/shared/src/index.ts"],
      "@property-app-ai/shared/*": ["../../libs/shared/src/*"]
