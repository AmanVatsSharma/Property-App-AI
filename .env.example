# Property-App-AI (UrbanNest.ai) — example env. Copy to .env and fill; never commit .env.
# API (NestJS) — set in repo root or when running apps/api
NODE_ENV=development
PORT=3333
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=property_app
LOG_LEVEL=debug
THROTTLE_TTL=60
THROTTLE_LIMIT=100
CORS_ORIGIN=*
# JWT: set in production (min 16 chars); when unset, auth is skipped
# JWT_SECRET=
JWT_EXPIRES_IN=7d
# Role allowlists (comma-separated phone numbers, normalized 10 digits)
# ADMIN_PHONES=9876543210
# BROKER_PHONES=9876543210,9123456789
# SMS (OTP): set for production; stub logs only when unset
# SMS_PROVIDER=stub
# SMS_PROVIDER=twilio → set TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# SMS_PROVIDER=msg91 → set MSG91_AUTH_KEY (optional: MSG91_SENDER)
# MSG91_AUTH_KEY=
# MSG91_SENDER=SMSIND
# AI agent — at least one provider
OPENAI_API_KEY=
AGENT_MODEL=gpt-4o
AGENT_PROVIDER=openai
# ANTHROPIC_API_KEY=
# AGENT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# AGENT_THINKING_BUDGET_TOKENS=
AGENT_MAX_STEPS=10
AGENT_PLAN_FIRST=false
# Optional async agent queue
AGENT_QUEUE_ENABLED=false
REDIS_URL=
AGENT_RATE_LIMIT_PER_MIN=10

# Web (Next.js) — NEXT_PUBLIC_* are exposed to the browser
# NEXT_PUBLIC_API_URL=http://localhost:3333
# NEXT_PUBLIC_GRAPHQL_HTTP=http://localhost:3333/graphql

# Mobile (Expo) — set for dev and prod so app can reach API
# EXPO_PUBLIC_API_URL=http://localhost:3333
# EXPO_PUBLIC_GRAPHQL_HTTP=http://localhost:3333/graphql
